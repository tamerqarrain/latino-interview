ANTHROPIC_API_KEY=your_anthropic_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here
DEEPGRAM_API_KEY=your_deepgram_key_here

# Optional: customize the ElevenLabs voice ID
# Default is "Adam" - a clear, professional male voice
# Find voice IDs at: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Email reports to HR (Resend) ──
# Get a free API key at https://resend.com (3,000 emails/month free)
RESEND_API_KEY=your_resend_key_here
# Where interview reports are sent (comma-separated for multiple recipients)
HR_EMAIL=hr@yourschool.com
# Sender address. Use onboarding@resend.dev for testing, or your verified domain
FROM_EMAIL=onboarding@resend.dev

# ── Google Sheets logging (optional, for searchable history) ──
# 1. Create a service account in Google Cloud Console
# 2. Enable Google Sheets API
# 3. Share your sheet with the service account email (as Editor)
# 4. Paste values below (the private key MUST keep \n as literal characters when stored)
GOOGLE_SHEET_ID=your_sheet_id_from_url
GOOGLE_SERVICE_ACCOUNT_EMAIL=name@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_TAB=Sheet1
